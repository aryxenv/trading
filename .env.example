# Copy to .env and fill with live IBKR API values.
# Never commit .env.

IBKR_HOST=127.0.0.1
# Live TWS usually 7496. Live IB Gateway usually 4001. Paper ports are blocked.
IBKR_PORT=7496
# Any unused API client id.
IBKR_CLIENT_ID=7
# Find this in TWS account selector, Account Window, or IBKR Client Portal.
IBKR_ACCOUNT_ID=
IBKR_TIMEOUT_SECONDS=30
